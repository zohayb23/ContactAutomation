APP_NAME=ContactAutomationCloud
ENVIRONMENT=dev
API_TOKEN=change-this-token

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/contact_automation
REDIS_URL=redis://redis:6379/0

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_SENDER_EMAIL=your-email@example.com
SMTP_USE_TLS=true

DEDUPE_WINDOW_DAYS=14
DEFAULT_MAX_SEND_PER_RUN=50
MAX_REQUESTS_PER_MINUTE=20
